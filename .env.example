APP_NAME="Blib"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en

ADMIN_NAME="Administrador"
ADMIN_EMAIL=admin@example.com
# Deve ter 12+ caracteres com maiúsculas, minúsculas, números e caracteres especiais
ADMIN_PASSWORD=
ADMIN_PHONE=

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=blib
DB_USERNAME=blib
DB_PASSWORD=

CACHE_STORE=redis
CACHE_LIMITER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=60
SESSION_IDLE_TIMEOUT=30
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_EXPIRE_ON_CLOSE=true

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_RETRY_AFTER=150

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

TRUSTED_PROXIES=
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
LOG_CHANNEL=stack
LOG_LEVEL=info

# Site institucional (Cirna)
CLIENT_NAME="Cirna"
# E-mail exibido publicamente no site
CIRNA_PUBLIC_EMAIL=contato@cirna.com.br
# Destino do formulário de contato
CIRNA_CONTACT_EMAIL=contato@cirna.com.br
# WhatsApp em formato internacional só com dígitos (ex.: 5554999999999). Vazio = botão oculto
CIRNA_WHATSAPP=
